---
interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const siteTitle = 'Matter of Matter';
const {
  title = siteTitle,
  description = 'Personal essays from Matter of Matter.',
  pageClass = '',
} = Astro.props;
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <title>{pageTitle}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --paper: #f7f7f5;
        --surface: #ffffff;
        --ink: #202024;
        --muted: #6f6b76;
        --line: #dedbe3;
        --accent: #5b4b8a;
        --accent-strong: #3f3268;
        --accent-soft: #eeeaf7;
        --measure: 720px;
        --wide: 1040px;
        --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --serif: Georgia, 'Times New Roman', serif;
        font-family: var(--serif);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-size: 18px;
        line-height: 1.75;
      }

      a {
        color: var(--accent-strong);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      a:hover {
        color: var(--accent);
      }

      a:focus-visible {
        border-radius: 3px;
        outline: 3px solid var(--accent-soft);
        outline-offset: 3px;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
        margin: 2rem auto;
      }

      .site-shell {
        width: min(100% - 32px, var(--wide));
        margin: 0 auto;
      }

      .site-header {
        background: color-mix(in srgb, var(--paper) 90%, white);
        border-bottom: 1px solid var(--line);
        margin-bottom: clamp(2.5rem, 6vw, 5rem);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.1rem 0;
      }

      .brand {
        color: var(--ink);
        font-family: var(--sans);
        font-size: 0.9rem;
        font-weight: 750;
        letter-spacing: 0.08em;
        text-decoration: none;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        gap: 1.2rem;
        font-family: var(--sans);
        font-size: 0.86rem;
      }

      main {
        padding-bottom: 5rem;
      }

      .content-shell {
        width: min(100% - 32px, var(--measure));
      }

      .home-masthead {
        border-bottom: 1px solid var(--line);
        display: grid;
        gap: 1.4rem;
        grid-template-columns: minmax(0, 1fr) minmax(170px, 240px);
        margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
        padding-bottom: clamp(2rem, 6vw, 4rem);
      }

      .home-title {
        font-size: clamp(3.8rem, 12vw, 8.5rem);
        letter-spacing: 0;
        line-height: 0.9;
        margin: 0;
      }

      .home-note {
        align-self: end;
        border-left: 3px solid var(--accent);
        color: var(--muted);
        font-family: var(--sans);
        font-size: 0.95rem;
        line-height: 1.55;
        padding-left: 1rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.2;
      }

      h1 {
        margin: 0 0 1rem;
        font-size: clamp(2.4rem, 7vw, 5.3rem);
        font-weight: 500;
      }

      h2 {
        margin-top: 2.5rem;
        font-size: 1.6rem;
        font-weight: 500;
      }

      .lede {
        color: var(--muted);
        font-size: clamp(1.1rem, 2vw, 1.3rem);
        max-width: 680px;
      }

      .section-label,
      .meta,
      .read-link,
      .year-label {
        font-family: var(--sans);
      }

      .section-label {
        color: var(--accent);
        font-size: 0.76rem;
        font-weight: 750;
        letter-spacing: 0.12em;
        margin: 0 0 0.9rem;
        text-transform: uppercase;
      }

      .post-list {
        display: grid;
        gap: 0;
        margin-top: 2.5rem;
      }

      .meta {
        color: var(--muted);
        font-size: 0.84rem;
      }

      .post-row {
        border-top: 1px solid var(--line);
        display: grid;
        gap: 0.55rem;
        padding: 1.35rem 0;
      }

      .post-row.with-media {
        grid-template-columns: minmax(0, 1fr) 112px;
        column-gap: 1.25rem;
      }

      .post-row.with-media > div {
        min-width: 0;
      }

      .post-thumb {
        aspect-ratio: 1;
        border: 1px solid var(--line);
        height: auto;
        margin: 0;
        object-fit: cover;
        width: 112px;
      }

      .post-row h2,
      .post-row h3 {
        font-size: clamp(1.25rem, 3vw, 1.65rem);
        font-weight: 500;
        margin: 0;
      }

      .post-row p {
        color: var(--muted);
        font-size: 1rem;
        margin: 0;
        max-width: 660px;
      }

      .read-link {
        font-size: 0.84rem;
        font-weight: 700;
        text-decoration: none;
      }

      .feature-post {
        background: var(--surface);
        border: 1px solid var(--line);
        border-left: 5px solid var(--accent);
        display: grid;
        gap: 1.5rem;
        grid-template-columns: minmax(0, 1fr) minmax(180px, 280px);
        padding: clamp(1.4rem, 4vw, 2.2rem);
      }

      .feature-post h1 {
        max-width: 820px;
      }

      .feature-post .feature-image {
        align-self: end;
        aspect-ratio: 4 / 5;
        background: var(--accent-soft);
        border: 1px solid var(--line);
        object-fit: cover;
        width: 100%;
      }

      .archive-preview,
      .recent-section,
      .year-group,
      .post-nav {
        margin-top: clamp(2.8rem, 7vw, 5rem);
      }

      .archive-preview-grid {
        border-top: 1px solid var(--line);
        display: grid;
        gap: 0;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .archive-preview-item {
        border-bottom: 1px solid var(--line);
        padding: 1.15rem 1.15rem 1.15rem 0;
      }

      .archive-preview-item h3 {
        font-size: 1.1rem;
        font-weight: 500;
        margin: 0.35rem 0 0;
      }

      .year-group {
        border-top: 1px solid var(--line);
        display: grid;
        grid-template-columns: 120px minmax(0, 1fr);
        column-gap: 2rem;
      }

      .year-label {
        color: var(--accent);
        font-size: 0.86rem;
        font-weight: 750;
        padding-top: 1.45rem;
      }

      .post-body {
        font-size: 1.08rem;
        margin-top: clamp(2.5rem, 7vw, 4.5rem);
      }

      .post-body :where(p, ul, ol, blockquote, div) {
        margin-block: 1.25rem;
      }

      .post-body :where(h2, h3) {
        margin-top: 2.4rem;
      }

      .post-body a {
        overflow-wrap: anywhere;
      }

      .post-body blockquote {
        border-left: 3px solid var(--accent);
        color: var(--muted);
        padding-left: 1.1rem;
      }

      .post-body .separator {
        clear: both;
      }

      .post-body img {
        border: 1px solid var(--line);
        max-height: 720px;
        object-fit: contain;
      }

      .article-header {
        border-bottom: 1px solid var(--line);
        border-top: 5px solid var(--accent);
        padding-bottom: clamp(2rem, 6vw, 3.5rem);
        padding-top: 1.5rem;
      }

      .article-header h1 {
        max-width: 860px;
      }

      .article-kicker {
        margin-bottom: 1rem;
      }

      .post-nav {
        border-top: 1px solid var(--line);
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        padding-top: 1.5rem;
      }

      .post-nav a {
        text-decoration: none;
      }

      .post-nav strong {
        display: block;
        font-size: 1.1rem;
        font-weight: 500;
        margin-top: 0.25rem;
      }

      .post-nav-next {
        text-align: right;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-family: var(--sans);
        font-size: 0.9rem;
        padding: 2rem 0;
      }

      @media (max-width: 760px) {
        body {
          font-size: 17px;
        }

        .site-shell,
        .content-shell {
          width: min(100% - 28px, var(--wide));
        }

        .nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .feature-post,
        .home-masthead,
        .year-group,
        .post-nav {
          grid-template-columns: 1fr;
        }

        .feature-post .feature-image {
          aspect-ratio: 16 / 9;
          max-width: 320px;
        }

        .post-row.with-media {
          grid-template-columns: 1fr;
        }

        .post-thumb {
          aspect-ratio: 16 / 9;
          width: min(100%, 320px);
        }

        .archive-preview-grid {
          grid-template-columns: 1fr;
        }

        .year-label {
          padding-top: 0;
        }

        .post-nav-next {
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell nav">
        <a class="brand" href="/">Matter of Matter</a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/archive.html">Archive</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </header>
    <main class={`site-shell ${pageClass}`}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">Matter of Matter</div>
    </footer>
  </body>
</html>
